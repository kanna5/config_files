; Note: This file is loaded before $HOME/.gitconfig

[init]
    defaultBranch = main

[core]
    pager = delta

[alias]
    graph = log --date=default-local --graph
    sign = commit --amend --no-edit --gpg-sign
    ff = merge --ff-only
    root = rev-parse --show-toplevel

    # Difftastic
    difft = -c core.pager='less -iRFX' -c diff.external=difft diff
    dft   = -c core.pager='less -iRFX' -c diff.external=difft diff
    dlog  = -c core.pager='less -iRFX' -c diff.external=difft log --ext-diff
    dshow = -c core.pager='less -iRFX' -c diff.external=difft show --ext-diff

[tag]
    sort = version:refname

[gpg]
    format = ssh

[versionsort]
    suffix = -

[log]
    decorate = short

[diff]
    algorithm = histogram
    colorMoved = true
    mnemonicPrefix = true
    renames = true

[branch]
    sort = -committerdate

[commit]
    verbose = true

[fetch]
    all = true

[push]
    autoSetupRemote = true

[merge]
    conflictStyle = zdiff3

[rebase]
    autosquash = true
    autostash = true

[interactive]
    diffFilter = delta --color-only

[delta]
    line-numbers = true
    navigate = true
    ; side-by-side = true

    syntax-theme = "gruvbox-dark"
    dark = true
    line-numbers-minus-style = 9
    line-numbers-plus-style = 10
    line-numbers-zero-style = 8
    plus-style = syntax "#3a3a19"
    plus-emph-style = 0 10
    minus-style = syntax "#481b1a"
    minus-emph-style = 0 9
    hunk-header-style = yellow ul
    hunk-header-decoration-style = 0 ul
    file-decoration-style = blue box
